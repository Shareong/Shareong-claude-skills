#!/usr/bin/env bash
# 全局 skill 管理脚本
# 用法：
#   skill a <name>    # 在当前项目引入 skill
#   skill ag <name>   # 全局引入 skill（所有项目可用）
#   skill rm <name>   # 从当前项目移除 skill
#   skill rmg <name>  # 从全局移除 skill
#   skill ls          # 列出仓库中所有可用 skills

REPO="$HOME/claude-skills"

case "$1" in
  a)
    name="$2"
    if [ -z "$name" ]; then echo "Usage: skill a <name>"; exit 1; fi
    if [ ! -d "$REPO/$name" ]; then echo "Error: skill '$name' not found in $REPO"; exit 1; fi
    mkdir -p ".claude/skills"
    if [ -e ".claude/skills/$name" ]; then
      ln -sf "$REPO/$name" ".claude/skills/$name"
      echo "✓ Updated skill '$name' in current project (.claude/skills/$name)"
    else
      ln -sf "$REPO/$name" ".claude/skills/$name"
      echo "✓ Added skill '$name' to current project (.claude/skills/$name)"
    fi
    ;;
  ag)
    name="$2"
    if [ -z "$name" ]; then echo "Usage: skill ag <name>"; exit 1; fi
    if [ ! -d "$REPO/$name" ]; then echo "Error: skill '$name' not found in $REPO"; exit 1; fi
    mkdir -p "$HOME/.claude/skills"
    if [ -e "$HOME/.claude/skills/$name" ]; then
      ln -sf "$REPO/$name" "$HOME/.claude/skills/$name"
      echo "✓ Updated skill '$name' globally (~/.claude/skills/$name)"
    else
      ln -sf "$REPO/$name" "$HOME/.claude/skills/$name"
      echo "✓ Added skill '$name' globally (~/.claude/skills/$name)"
    fi
    ;;
  rm)
    name="$2"
    if [ -z "$name" ]; then echo "Usage: skill rm <name>"; exit 1; fi
    rm -f ".claude/skills/$name"
    echo "✓ Removed skill '$name' from current project"
    ;;
  rmg)
    name="$2"
    if [ -z "$name" ]; then echo "Usage: skill rmg <name>"; exit 1; fi
    rm -f "$HOME/.claude/skills/$name"
    echo "✓ Removed skill '$name' from global skills"
    ;;
  ls)
    echo "Available skills in $REPO:"
    echo ""
    for d in "$REPO"/*/; do
      sname=$(basename "$d")
      if [ -f "$d/SKILL.md" ]; then
        desc=$(grep -m1 "^description:" "$d/SKILL.md" | sed 's/^description: *//')
        printf "  %-20s %s\n" "$sname" "$desc"
      fi
    done
    ;;
  *)
    echo "Claude Skills Manager"
    echo ""
    echo "Usage: skill <command> [name]"
    echo ""
    echo "Commands:"
    echo "  a <name>    Add skill to current project"
    echo "  ag <name>   Add skill globally (all projects)"
    echo "  rm <name>   Remove skill from current project"
    echo "  rmg <name>  Remove skill from global"
    echo "  ls          List all available skills"
    ;;
esac
